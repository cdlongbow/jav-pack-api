{
  "name": "jav-pack-api",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "check": "oxfmt --check && oxlint",
    "deploy": "wrangler deploy --minify",
    "dev": "wrangler dev",
    "fix": "oxfmt && oxlint --fix",
    "migrate": "wrangler d1 migrations apply jav-pack-api-db",
    "migrate:local": "pnpm migrate -- --local",
    "migrate:remote": "pnpm migrate -- --remote",
    "predeploy": "pnpm check"
  },
  "dependencies": {
    "hono": "^4.12.19"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "wrangler": "^4.92.0"
  },
  "packageManager": "pnpm@11.1.2"
}
